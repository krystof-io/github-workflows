<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!-- False positive: CVE-2022-31691 is for Spring Tools 4 IDE (Eclipse/VSCode plugins),
         not spring-boot-devtools. The CPE matcher incorrectly matches on "spring_boot_tools". -->
    <suppress>
        <notes><![CDATA[
            CVE-2022-31691 affects Spring Tools 4 for Eclipse and VSCode extensions (Snakeyaml vulnerability),
            not spring-boot-devtools. spring-boot-devtools is also runtime+optional and excluded from production builds.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.springframework\.boot/spring\-boot\-devtools@.*$</packageUrl>
        <cve>CVE-2022-31691</cve>
    </suppress>

    <!--                                                                    
       CVE-2026-29062: Nesting Depth Constraint Bypass in UTF8DataInputJsonParser (CVSS 8.7)
       Fixed in Jackson 3.1.0, but Spring Boot 4.0.3 ships Jackson 3.0.4.
       Jackson 3.0.x is not LTS and will not receive a patch; Spring Boot will
       upgrade to Jackson 3.1 in a future release.                            
       Risk is mitigated: all JSON-accepting endpoints require authentication,   
       and @Valid DTOs are shallow structures that reject deeply-nested input.
       Tracking: https://github.com/spring-projects/spring-framework/issues/36130
                 https://github.com/spring-projects/spring-boot/issues/49365
       Suppress until: Spring Boot upgrades to Jackson 3.1+
   -->
    <suppress>
        <notes><![CDATA[                                                       
           Suppressed pending Spring Boot upgrade to Jackson 3.1+.
           All inbound JSON is behind authentication; flat DTOs limit nesting.
       ]]></notes>
        <cve>CVE-2026-29062</cve>
    </suppress>

    <!--
        CVE-2025-15599 & CVE-2026-0540: DOMPurify XSS bypass via missing rawtext
        elements in SAFE_FOR_XML regex. Fixed in DOMPurify 3.3.2 / 2.5.9, but
        swagger-ui 5.32.0 (latest) still bundles a vulnerable version.
        No upstream fix available yet.
        Risk is mitigated: Swagger UI is restricted to non-production profiles only.
        Tracking: https://github.com/swagger-api/swagger-ui/issues/10478
        Suppress until: swagger-ui ships with DOMPurify >= 3.3.2
    -->
    <suppress>
        <notes><![CDATA[
            Suppressed pending swagger-ui upgrade of bundled DOMPurify.
            Swagger UI is disabled in production profiles.
        ]]></notes>
        <filePath regex="true">.*swagger-ui.*\.jar.*</filePath>
        <cve>CVE-2025-15599</cve>
    </suppress>
    <suppress>
        <notes><![CDATA[
            Suppressed pending swagger-ui upgrade of bundled DOMPurify.
            Swagger UI is disabled in production profiles.
        ]]></notes>
        <filePath regex="true">.*swagger-ui.*\.jar.*</filePath>
        <cve>CVE-2026-0540</cve>
    </suppress>

    <!--
        CVE-2026-0994: DoS via recursion depth bypass in protobuf ParseDict().
        This vulnerability is Python-only (google.protobuf.json_format.ParseDict).
        The Java protobuf library does not contain this code path.
        OWASP Dependency-Check matches the CVE to protobuf-java by artifact name.
        Suppress until: NVD corrects the CPE scope to exclude Java.
    -->
    <suppress>
        <notes><![CDATA[
            Python-only vulnerability in protobuf json_format.ParseDict().
            Does not affect protobuf-java.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/com\.google\.protobuf/protobuf\-java@.*$</packageUrl>
        <cve>CVE-2026-0994</cve>
    </suppress>

</suppressions>