<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!-- False positive: CVE-2022-31691 is for Spring Tools 4 IDE (Eclipse/VSCode plugins),
         not spring-boot-devtools. The CPE matcher incorrectly matches on "spring_boot_tools". -->
    <suppress>
        <notes><![CDATA[
            CVE-2022-31691 affects Spring Tools 4 for Eclipse and VSCode extensions (Snakeyaml vulnerability),
            not spring-boot-devtools. spring-boot-devtools is also runtime+optional and excluded from production builds.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.springframework\.boot/spring\-boot\-devtools@.*$</packageUrl>
        <cve>CVE-2022-31691</cve>
    </suppress>

    <!--                                                                    
       CVE-2026-29062: Nesting Depth Constraint Bypass in UTF8DataInputJsonParser (CVSS 8.7)
       Fixed in Jackson 3.1.0, but Spring Boot 4.0.3 ships Jackson 3.0.4.
       Jackson 3.0.x is not LTS and will not receive a patch; Spring Boot will
       upgrade to Jackson 3.1 in a future release.                            
       Risk is mitigated: all JSON-accepting endpoints require authentication,   
       and @Valid DTOs are shallow structures that reject deeply-nested input.
       Tracking: https://github.com/spring-projects/spring-framework/issues/36130
                 https://github.com/spring-projects/spring-boot/issues/49365
       Suppress until: Spring Boot upgrades to Jackson 3.1+
   -->
    <suppress>
        <notes><![CDATA[                                                       
           Suppressed pending Spring Boot upgrade to Jackson 3.1+.
           All inbound JSON is behind authentication; flat DTOs limit nesting.
       ]]></notes>
        <cve>CVE-2026-29062</cve>
    </suppress>

</suppressions>